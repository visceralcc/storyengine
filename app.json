{
  "expo": {
    "name": "Story Engine",
    "slug": "storyengine",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "storyengine",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.storyengine.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.storyengine.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
